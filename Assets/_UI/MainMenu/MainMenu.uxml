<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/_UI/MainMenu/main-menu-styles.uss?fileID=7433441132597879392&amp;guid=423fb87ba53d8f340be2604e3628f8ec&amp;type=3#main-menu-styles" />
    <ui:VisualElement name="Root" class="root" style="flex-grow: 1;">
        <ui:VisualElement name="Background_Image" class="background-image" style="flex-grow: 1;" />
        <ui:VisualElement name="Panel" class="panel" style="flex-grow: 1;">
            <ui:VisualElement name="TitleText_Container" class="title-text-container" style="flex-grow: 1;">
                <ui:Label text="CUBE&#10;FALL" name="TitleText_Label" class="title-text-label" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/Jersey10-Regular.ttf?fileID=12800000&amp;guid=99699f012aefb804db0bb144942b5d7d&amp;type=3#Jersey10-Regular&quot;); font-size: 110px; color: rgb(95, 179, 255);" />
            </ui:VisualElement>
            <ui:VisualElement name="Button_Container" class="button-container" style="flex-grow: 1; justify-content: flex-start; align-self: auto; align-items: stretch; margin-top: 30px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;">
                <ui:Button text="Play" name="Play_Button" class="main-menu-button" />
                <ui:Button text="Settings" name="Settings_Button" class="main-menu-button" />
                <ui:Button text="Credits" name="Credits_Button" class="main-menu-button" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
